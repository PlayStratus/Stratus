# Backend API URL
# For production deployment, set this to your AWS API Gateway URL
# For local development, set to http://localhost:4000
NEXT_PUBLIC_BACKEND_PATH=http://localhost:4000

# The Google client ID used for OAuth
GOOGLE_CLIENT_ID=0123456789abcdef.apps.googleusercontent.com

# The WebTransport port on the streaming servers (defaults to 443)
NEXT_PUBLIC_STRATUSD_PORT=443

# Whether to enable static export mode. Handled by build:static script
NEXT_PUBLIC_STATIC_EXPORT=false
