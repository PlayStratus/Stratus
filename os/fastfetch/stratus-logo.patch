+$1#######$2==========================
+$1#####$2===========================
+$1###$2===========================
+$1##$3........$2================$3...
+       $3.........     .......
+          $3................
+             $3...........
\ No newline at end of file
diff --git a/src/logo/builtin.c b/src/logo/builtin.c
index 7e1dc330..d1cc7934 100644
--- a/src/logo/builtin.c
+++ b/src/logo/builtin.c
@@ -4791,6 +4791,16 @@ static const FFlogo S[] = {
         .colorKeys = FF_COLOR_FG_RED,
         .colorTitle = FF_COLOR_FG_RED,
     },
+    // Stratus OS
+    {
+        .names = {"stratus", "Stratus OS"},
+        .lines = FASTFETCH_DATATEXT_LOGO_STRATUS,
+        .colors = {
+            FF_COLOR_FG_BLUE,
