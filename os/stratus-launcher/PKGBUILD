# Maintainer: Stratus

pkgname=stratus-launcher
pkgver=0.0
pkgrel=1
pkgdesc='The stratus game launcher'
arch=('x86_64')
url='https://github.com/playstratus/stratus'
license=('MIT')

depends=('bubblewrap' 'curl' 'fuse' 'unzip' 'wine' 'winetricks' 'wine-mono')
optdepends=('stratusd: stratus-launcher-init.service')
makedepends=('git')

provides=('stratus-launcher')

options=('!debug')

source=(
  # TODO: This isn't quite best-practice, we should just download a release
  # tarball from GitHub instead once Stratus is published.
  "stratus::git+file://$(git rev-parse --show-toplevel)"

  'stratus-launcher-init.service'
)
sha256sums=('SKIP' 'SKIP')

pkgver() {
  git describe --tags --long --always | sed 's/\([^-]*-g\)/r\1/;s/-/./g'
}

package() {
  install -Dm755 "$srcdir/stratus/games/stratus-launcher.sh" "$pkgdir/usr/bin/stratus-launcher"
  install -Dm644 "$srcdir/stratus-launcher-init.service" "$pkgdir/usr/lib/systemd/user/stratus-launcher-init.service"
}
