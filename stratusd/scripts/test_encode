# Delete past artifacts
rm data/{big_buck_bunny_ARGB.raw,big_buck_bunny_decoded.mp4,output.h624}

# Build latest version
cmake --build ./build/

# Create raw ARGB8888 data
ffmpeg -i data/big_buck_bunny.mp4 -pix_fmt argb -vf format=argb -f rawvideo data/big_buck_bunny_ARGB.raw

./build/stratusd

# Convert encoded data back to .mp4
ffmpeg -i data/output.h264 -c:v copy data/big_buck_bunny_decoded.mp4

# Compare
ffmpeg -i data/big_buck_bunny.mp4 -i data/big_buck_bunny_decoded.mp4 -lavfi psnr=psnr.log -f null -

